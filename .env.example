# UMKN POS Environment Variables
# Copy file ini ke .env dan isi dengan values kamu

# Database URL ( dari Neon )
# Format: postgresql://username:password@host.neon.tech/umkn_pos?sslmode=require
DATABASE_URL="postgresql://username:password@host.neon.tech/umkn_pos?sslmode=require"

# JWT Secret ( buat random string min 32 karakter )
JWT_SECRET="your-super-secret-key-min-32-characters-long-here"

# API URL ( kosongin kalau running di local )
NEXT_PUBLIC_API_URL=""